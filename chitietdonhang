CSSS


* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: #f7f7f7;
  color: #222;
  font-size: 14px;
}

a {
  text-decoration: none;
  color: inherit;
}

.container {
  width: 92%;
  max-width: 1180px;
  margin: 0 auto;
}

/* Header */
.site-header {
  background: #fff;
  border-bottom: 1px solid #ddd;
}

.top-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 10px 0;
}

.logo {
  font-size: 22px;
  font-weight: 700;
  color: #2e5bd7;
  min-width: 120px;
}

.search-box {
  flex: 1;
  max-width: 520px;
  display: flex;
  align-items: center;
  background: #f1eef4;
  border-radius: 20px;
  overflow: hidden;
  height: 38px;
}

.search-box input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  padding: 0 14px;
  font-size: 13px;
}

.search-box button {
  border: none;
  background: transparent;
  width: 42px;
  cursor: pointer;
  color: #666;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18px;
}

.header-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 11px;
  color: #333;
  gap: 4px;
}

.header-action i {
  font-size: 20px;
}

.main-nav {
  border-top: 1px solid #f0f0f0;
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 40px;
  padding: 14px 0;
  font-size: 14px;
  font-weight: 600;
}

.nav-inner a:hover {
  color: #2e5bd7;
}

/* Breadcrumb */
.breadcrumb-wrap {
  background: #fafafa;
  border-bottom: 1px solid #ececec;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 0;
  font-size: 13px;
  color: #8a8a8a;
}

.breadcrumb strong {
  color: #444;
}

/* Main content */
.page-content {
  padding: 30px 0 80px;
  min-height: 600px;
}

/* Progress */
.progress-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 34px;
}

.progress-step {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #333;
  font-size: 12px;
  white-space: nowrap;
}

.circle {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #3f6fe5;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
}

.progress-line {
  width: 110px;
  height: 1px;
  background: #9db2ff;
  margin: 0 10px;
}

/* Title */
.order-title-box {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border: 1px solid #7e96f5;
  border-radius: 8px;
  padding: 10px 16px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  margin-bottom: 18px;
}

.title-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #3f6fe5;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
}

.order-title-box h2 {
  font-size: 20px;
  font-weight: 700;
  color: #444;
}

/* Summary */
.order-summary {
  margin-bottom: 36px;
  color: #444;
}

.order-summary ul {
  list-style: none;
  line-height: 1.9;
  font-size: 12px;
}

/* Section */
.section h3,
.address-card h3 {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 14px;
  color: #333;
}

.order-table {
  border-top: 1px solid #d9d9d9;
  padding-top: 12px;
}

.table-header,
.table-row {
  display: grid;
  grid-template-columns: 2.5fr 1fr 0.9fr 1.1fr;
  gap: 16px;
  align-items: center;
}

.table-header {
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 18px;
  color: #444;
}

.table-row {
  font-size: 14px;
  color: #444;
  margin-bottom: 20px;
}

.order-total {
  width: 280px;
  margin-left: auto;
  display: flex;
  flex-direction: column;
  gap: 14px;
  font-size: 14px;
  color: #444;
}

.order-total div {
  display: flex;
  justify-content: space-between;
  gap: 16px;
}

.order-total .grand-total {
  font-weight: 700;
}

/* Address */
.address-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  margin-top: 48px;
}

.card-box {
  background: #fff;
}

.card-status {
  background: #9fc3f0;
  color: #2f4d69;
  padding: 12px 14px;
  font-size: 13px;
}

.card-content {
  background: #fbfbfb;
  padding: 14px;
  min-height: 92px;
  line-height: 1.7;
  color: #444;
}

/* Footer */
.site-footer {
  margin-top: 60px;
  background: #fff;
  border-top: 1px solid #e3e3e3;
  padding: 36px 0 28px;
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.2fr 1fr;
  gap: 36px;
}

.footer-logo {
  font-size: 30px;
  font-weight: 700;
  color: #2e5bd7;
  margin-bottom: 10px;
}

.footer-col h4 {
  font-size: 13px;
  margin-bottom: 14px;
  color: #333;
}

.footer-col a,
.footer-col p,
.brand-col p {
  display: block;
  font-size: 12px;
  color: #555;
  line-height: 1.9;
  margin-bottom: 2px;
}

/* Responsive */
@media (max-width: 992px) {
  .top-header {
    flex-wrap: wrap;
  }

  .search-box {
    order: 3;
    width: 100%;
    max-width: 100%;
  }

  .nav-inner {
    gap: 20px;
    flex-wrap: wrap;
  }

  .address-section,
  .footer-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 768px) {
  .header-actions {
    gap: 12px;
  }

  .header-action span {
    font-size: 10px;
  }

  .progress-wrapper {
    flex-wrap: wrap;
    gap: 10px;
  }

  .progress-line {
    width: 50px;
    margin: 0;
  }

  .table-header {
    display: none;
  }

  .table-row {
    grid-template-columns: 1fr;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 14px;
  }

  .order-total {
    width: 100%;
    margin-top: 20px;
  }

  .address-section,
  .footer-grid {
    grid-template-columns: 1fr;
  }
}











